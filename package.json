    "next": "14.2.0",
    "next-auth": "^4.24.10",
    "next-themes": "^0.2.0",
    "pg": "^8.20.0",
    "prisma": "^5.22.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
